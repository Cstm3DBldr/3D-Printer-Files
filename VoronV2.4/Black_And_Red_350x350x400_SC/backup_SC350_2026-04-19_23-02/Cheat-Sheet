[pca9685 my_pca9685]
# Optional I2C parameters (see "common I2C settings" section for details):
#i2c_mcu: mcu
#i2c_bus: i2c_bus
#i2c_address: 0x40
#i2c_software_scl_pin:
#i2c_software_sda_pin:
#i2c_speed: 400000
frequency: 50  # PWM frequency in Hz (default: 50 for servos; range 24-1526)

This section configures a PCA9685 16-channel PWM driver over I2C. It exposes PWM pins
named "pca9685:my_pca9685:<channel>" where <channel> is 0-15. These can be used in
[servo], [output_pin], or [fan] sections for PWM control.

Example pins:
  pin: ^pca9685:my_pca9685:0  # Channel 0, inverted


## Useable
[i2c]
# Optional: Define an I2C bus (if not using default)
#i2c_mcu: mcu  # If on MCU, else omit for host
#i2c_bus: i2c1  # Default i2c1 on Pi

[pca9685 servo_board]
i2c_bus: i2c1  # Or just the bus name if host-side
i2c_address: 0x40  # Default PCA9685 address
frequency: 50  # 50 Hz for standard servos

[servo servo1]
pin: pca9685:servo_board:0
maximum_servo_angle: 180
minimum_pulse_width: 0.001
maximum_pulse_width: 0.002

[servo servo2]
pin: pca9685:servo_board:1
maximum_servo_angle: 180
minimum_pulse_width: 0.001
maximum_pulse_width: 0.002

# ... up to servo16 on channel 15

